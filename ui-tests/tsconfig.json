{
	"compilerOptions": {
		"target": "ES2021",
		"module": "CommonJS",
		"moduleResolution": "Node",
		"lib": ["ES2021", "DOM", "DOM.Iterable"],
		"types": ["node"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true
	},
	"include": ["**/*.ts"]
}
