// See https://go.microsoft.com/fwlink/?LinkId=733558
// for the documentation about the tasks.json format
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "compile",
			"type": "npm",
			"script": "compile",
			"problemMatcher": "$tsc",
			"presentation": {
				"reveal": "silent",
				"clear": true
			},
			"group": "build"
		},
		{
			"label": "watch",
			"type": "npm",
			"script": "watch",
			"problemMatcher": "$tsc-watch",
			"isBackground": true,
			"presentation": {
				"reveal": "never"
			},
			"group": "build"
		},
		{
			"label": "build:webview",
			"type": "npm",
			"script": "build:webview",
			"problemMatcher": [],
			"presentation": {
				"reveal": "silent"
			},
			"group": "build"
		},
		{
			"label": "watch:webview",
			"type": "npm",
			"script": "watch:webview",
			"isBackground": true,
			"problemMatcher": [],
			"presentation": {
				"reveal": "never"
			},
			"group": "build"
		},
		{
			"label": "build",
			"dependsOn": ["build:webview", "compile", "watch"],
			"dependsOrder": "sequence",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": []
		}
	]
}
